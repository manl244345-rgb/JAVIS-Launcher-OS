<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/bg_card"
    android:padding="10dp"
    android:layout_margin="4dp"
    android:gravity="center_vertical">
    <TextView android:id="@+id/tv_result"
        android:layout_width="24dp" android:layout_height="wrap_content"
        android:textSize="16sp" android:textColor="@color/javis_accent_green"/>
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
        android:orientation="vertical" android:layout_marginStart="8dp">
        <TextView android:id="@+id/tv_command"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="@color/javis_text_primary" android:textSize="14sp"/>
        <TextView android:id="@+id/tv_time"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="@color/javis_text_secondary" android:textSize="12sp"/>
    </LinearLayout>
</LinearLayout>
