<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/javis_bg_dark">
    <androidx.appcompat.widget.Toolbar android:id="@+id/toolbar"
        android:layout_width="match_parent" android:layout_height="?attr/actionBarSize"
        android:background="@color/javis_bg_surface"
        app:layout_constraintTop_toTopOf="parent"/>
    <LinearLayout android:id="@+id/toolbar_actions"
        android:layout_width="wrap_content" android:layout_height="?attr/actionBarSize"
        android:orientation="horizontal" android:gravity="center_vertical" android:paddingEnd="8dp"
        app:layout_constraintTop_toTopOf="parent" app:layout_constraintEnd_toEndOf="parent">
        <ImageButton android:id="@+id/btn_speak_last"
            android:layout_width="40dp" android:layout_height="40dp"
            android:src="@android:drawable/ic_lock_silent_mode_off"
            android:background="@color/transparent" android:tint="@color/javis_accent_blue"/>
        <ImageButton android:id="@+id/btn_clear"
            android:layout_width="40dp" android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_delete"
            android:background="@color/transparent" android:tint="@color/javis_text_secondary"/>
    </LinearLayout>
    <androidx.recyclerview.widget.RecyclerView android:id="@+id/rv_messages"
        android:layout_width="match_parent" android:layout_height="0dp"
        android:padding="8dp" android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toTopOf="@id/tv_typing"/>
    <TextView android:id="@+id/tv_typing"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="JAVIS is thinking…" android:textColor="@color/javis_accent_blue"
        android:textSize="13sp" android:paddingHorizontal="16dp" android:paddingVertical="4dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/input_layout" app:layout_constraintStart_toStartOf="parent"/>
    <LinearLayout android:id="@+id/input_layout"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:padding="8dp"
        android:background="@color/javis_bg_surface"
        app:layout_constraintBottom_toBottomOf="parent">
        <ImageButton android:id="@+id/btn_voice"
            android:layout_width="44dp" android:layout_height="44dp"
            android:src="@drawable/ic_mic" android:background="@color/transparent"/>
        <EditText android:id="@+id/et_input"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:hint="Ask JAVIS anything…" android:textColor="@color/javis_text_primary"
            android:textColorHint="@color/javis_text_secondary" android:background="@color/transparent"
            android:imeOptions="actionSend" android:inputType="textCapSentences|textAutoCorrect"
            android:paddingHorizontal="8dp" android:maxLines="3"/>
        <ImageButton android:id="@+id/btn_send"
            android:layout_width="44dp" android:layout_height="44dp"
            android:src="@drawable/ic_send" android:background="@color/transparent"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
