<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:gravity="center"
    android:padding="8dp" android:clickable="true" android:focusable="true">
    <ImageView android:id="@+id/iv_app_icon"
        android:layout_width="52dp" android:layout_height="52dp"
        android:scaleType="fitCenter" android:contentDescription="App Icon"/>
    <TextView android:id="@+id/tv_app_name"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:gravity="center" android:textColor="@color/javis_text_primary"
        android:textSize="11sp" android:maxLines="2" android:ellipsize="end"
        android:layout_marginTop="4dp"/>
</LinearLayout>
