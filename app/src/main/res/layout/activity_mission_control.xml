<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/javis_bg_dark">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/javis_bg_surface"
        app:title="Mission Control"
        app:titleTextColor="@color/javis_text_primary"
        app:navigationIcon="@drawable/ic_arrow_back"/>

    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent" android:padding="16dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
            <TextView android:id="@+id/tv_ai_provider" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textColor="@color/javis_accent_blue" android:textSize="16sp" android:padding="12dp"
                android:background="@drawable/bg_card" android:layout_marginBottom="8dp" android:text="AI: Loading..."/>
            <TextView android:id="@+id/tv_battery" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textColor="@color/javis_accent_green" android:textSize="16sp" android:padding="12dp"
                android:background="@drawable/bg_card" android:layout_marginBottom="8dp" android:text="Battery: Loading..."/>
            <TextView android:id="@+id/tv_memory_usage" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textColor="@color/javis_text_primary" android:textSize="16sp" android:padding="12dp"
                android:background="@drawable/bg_card" android:layout_marginBottom="8dp" android:text="RAM: Loading..."/>
            <TextView android:id="@+id/tv_notifications" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textColor="@color/javis_text_secondary" android:textSize="14sp" android:padding="12dp"
                android:background="@drawable/bg_card" android:layout_marginBottom="8dp" android:text="Notifications: Loading..."/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
