<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_card"
    android:padding="12dp"
    android:layout_margin="4dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
        <TextView android:id="@+id/tv_memory_key"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:textColor="@color/javis_accent_blue" android:textSize="14sp" android:textStyle="bold"/>
        <TextView android:id="@+id/tv_memory_type"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="@color/javis_text_secondary" android:textSize="11sp"/>
    </LinearLayout>
    <TextView android:id="@+id/tv_memory_value"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:textColor="@color/javis_text_primary" android:textSize="14sp" android:layout_marginTop="4dp"/>
</LinearLayout>
