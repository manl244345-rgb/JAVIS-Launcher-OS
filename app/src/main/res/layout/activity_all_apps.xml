<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/javis_bg_dark">
    <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
        android:orientation="horizontal" android:gravity="center_vertical" android:paddingHorizontal="8dp"
        android:background="@color/javis_bg_surface">
        <ImageButton android:id="@+id/btn_back"
            android:layout_width="44dp" android:layout_height="44dp"
            android:src="@drawable/ic_arrow_back" android:background="@color/transparent"/>
        <EditText android:id="@+id/et_search"
            android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1"
            android:hint="Search apps…" android:textColor="@color/javis_text_primary"
            android:textColorHint="@color/javis_text_secondary"
            android:background="@drawable/bg_search_bar" android:paddingHorizontal="16dp"
            android:inputType="text" android:imeOptions="actionSearch" android:layout_marginHorizontal="8dp"/>
    </LinearLayout>
    <androidx.recyclerview.widget.RecyclerView android:id="@+id/rv_apps"
        android:layout_width="match_parent" android:layout_height="match_parent"
        android:padding="4dp" android:clipToPadding="false"/>
</LinearLayout>
