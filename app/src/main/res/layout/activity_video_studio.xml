<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/javis_bg_dark">
    <androidx.appcompat.widget.Toolbar android:id="@+id/toolbar"
        android:layout_width="match_parent" android:layout_height="?attr/actionBarSize"
        android:background="@color/javis_bg_surface"
        app:navigationIcon="@drawable/ic_arrow_back"/>
    <VideoView android:id="@+id/video_view"
        android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
        android:background="@color/javis_bg_surface"/>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:padding="8dp" android:gravity="center" android:gap="8dp">
        <com.google.android.material.button.MaterialButton android:id="@+id/btn_pick_video"
            android:layout_width="wrap_content" android:layout_height="44dp" android:text="Pick Video"
            app:backgroundTint="@color/javis_accent_blue"/>
        <com.google.android.material.button.MaterialButton android:id="@+id/btn_play"
            android:layout_width="wrap_content" android:layout_height="44dp" android:text="▶ Play"
            app:backgroundTint="@color/javis_bg_surface" app:strokeColor="@color/javis_accent_green" app:strokeWidth="1dp"/>
        <com.google.android.material.button.MaterialButton android:id="@+id/btn_pause"
            android:layout_width="wrap_content" android:layout_height="44dp" android:text="⏸ Pause"
            app:backgroundTint="@color/javis_bg_surface" app:strokeColor="@color/javis_accent_red" app:strokeWidth="1dp"/>
        <com.google.android.material.button.MaterialButton android:id="@+id/btn_trim"
            android:layout_width="wrap_content" android:layout_height="44dp" android:text="✂ Trim"
            app:backgroundTint="@color/javis_bg_surface" app:strokeColor="@color/javis_accent_red" app:strokeWidth="1dp"/>
        <com.google.android.material.button.MaterialButton android:id="@+id/btn_caption"
            android:layout_width="wrap_content" android:layout_height="44dp" android:text="AI Caption"
            app:backgroundTint="@color/javis_accent_red"/>
    </LinearLayout>
</LinearLayout>
