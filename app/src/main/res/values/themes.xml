<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Javis" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/javis_accent_red</item>
        <item name="colorPrimaryVariant">@color/javis_accent_red</item>
        <item name="colorOnPrimary">@color/javis_text_primary</item>
        <item name="colorSecondary">@color/javis_accent_blue</item>
        <item name="colorSurface">@color/javis_bg_surface</item>
        <item name="android:colorBackground">@color/javis_bg_dark</item>
        <item name="android:textColorPrimary">@color/javis_text_primary</item>
        <item name="android:textColorSecondary">@color/javis_text_secondary</item>
        <item name="android:windowBackground">@color/javis_bg_dark</item>
        <item name="android:statusBarColor">@color/javis_bg_dark</item>
        <item name="android:navigationBarColor">@color/javis_bg_dark</item>
    </style>
    <style name="Theme.Javis.Launcher" parent="Theme.Javis">
        <item name="android:windowShowWallpaper">false</item>
        <item name="android:windowIsTranslucent">false</item>
    </style>
    <style name="Theme.Javis.Dark" parent="Theme.Javis">
        <item name="android:windowBackground">@color/javis_bg_dark</item>
    </style>
</resources>
