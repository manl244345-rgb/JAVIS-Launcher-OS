<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/javis_bg_dark">

    <!-- Top gradient overlay -->
    <View android:layout_width="match_parent" android:layout_height="120dp"
        android:background="#AA0D0D1A"
        app:layout_constraintTop_toTopOf="parent"/>

    <!-- Greeting -->
    <TextView android:id="@+id/tv_greeting"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Good morning, Sir" android:textColor="@color/javis_text_primary"
        android:textSize="20sp" android:fontFamily="sans-serif-light" android:letterSpacing="0.05"
        app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" android:layout_marginTop="52dp"/>

    <!-- Date/Time -->
    <TextView android:id="@+id/tv_datetime"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Monday, Jun 23" android:textColor="@color/javis_text_secondary"
        android:textSize="13sp" android:letterSpacing="0.08"
        app:layout_constraintTop_toBottomOf="@id/tv_greeting"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="4dp"/>

    <!-- Skull Orb -->
    <com.javis.launcher.ui.home.OrbView
        android:id="@+id/orb_view"
        android:layout_width="240dp" android:layout_height="240dp"
        android:clickable="true" android:focusable="true"
        app:layout_constraintTop_toBottomOf="@id/tv_datetime"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp"/>

    <!-- Status text -->
    <TextView android:id="@+id/tv_status"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Tap orb to speak" android:textColor="@color/javis_text_secondary"
        android:textSize="13sp" android:letterSpacing="0.12" android:textAllCaps="true"
        app:layout_constraintTop_toBottomOf="@id/orb_view"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp"/>

    <!-- Swipe hint labels -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="↑ Apps" android:textColor="@color/javis_text_dim" android:textSize="11sp"
        app:layout_constraintTop_toTopOf="@id/orb_view" app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" android:layout_marginTop="0dp"/>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="← Memory" android:textColor="@color/javis_text_dim" android:textSize="11sp"
        app:layout_constraintTop_toTopOf="@id/orb_view" app:layout_constraintBottom_toBottomOf="@id/orb_view"
        app:layout_constraintStart_toStartOf="parent" android:layout_marginStart="12dp"/>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Chat →" android:textColor="@color/javis_text_dim" android:textSize="11sp"
        app:layout_constraintTop_toTopOf="@id/orb_view" app:layout_constraintBottom_toBottomOf="@id/orb_view"
        app:layout_constraintEnd_toEndOf="parent" android:layout_marginEnd="12dp"/>

    <!-- Favorites strip -->
    <LinearLayout android:id="@+id/favorites_container"
        android:layout_width="match_parent" android:layout_height="72dp"
        android:orientation="horizontal" android:gravity="center"
        android:paddingHorizontal="16dp"
        app:layout_constraintBottom_toTopOf="@id/search_bar"
        android:layout_marginBottom="8dp"/>

    <!-- Search bar -->
    <EditText android:id="@+id/search_bar"
        android:layout_width="0dp" android:layout_height="50dp"
        android:layout_marginHorizontal="20dp" android:layout_marginBottom="24dp"
        android:background="@drawable/bg_search_bar"
        android:hint="Search or ask JAVIS…"
        android:textColor="@color/javis_text_primary"
        android:textColorHint="@color/javis_text_secondary"
        android:paddingHorizontal="20dp" android:inputType="text"
        android:imeOptions="actionSearch" android:singleLine="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
